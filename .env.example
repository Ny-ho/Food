# Food Decision API — Environment Configuration Example
# Copy this file to .env and fill in the values before running.

# App settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# IP Geolocation (free, no key needed)
IP_GEO_URL=http://ip-api.com/json/

# OpenStreetMap Overpass API (free, no key needed)
OVERPASS_URL=https://overpass-api.de/api/interpreter

# Nominatim (free, no key needed) — geocoding
NOMINATIM_USER_AGENT=food_decision_app

# Foursquare Places API (Free Tier)
# Get a key from: https://location.foursquare.com/developer/
FSQ_API_KEY=your_foursquare_api_key_here
